# Copy to .env and set your values. Do not commit .env.
#
# This example supports three runtime paths:
# 1. Teams / Azure Bot + local Graph mail MCP server
# 2. Local front-end smoke
# 3. Local telemetry-only smoke
#
# zsh note:
# Quote values that contain * or ? (for example URL='*') or `source .env`
# may fail with "no matches found".

# ---------------------------------------------------------------------------
# A365 / Entra client credentials
# Used by scripts/get_a365_token.py to mint A365 bearer tokens.
# ---------------------------------------------------------------------------
AZURE_TENANT_ID=<entra-tenant-id>
AZURE_CLIENT_ID=<entra-app-client-id>
AZURE_CLIENT_SECRET=<entra-app-client-secret>

# For A365 traces, prefer the blueprint scope below.
A365_TOKEN_SCOPE=api://AzureADTokenExchange/.default

# Optional. Set if the token request requires fmi_path / agent identity client id.
A365_FMI_PATH=<agent-identity-client-id>
A365_TENANT_ID=<agent365-tenant-id>
A365_RUNTIME_AGENT_ID=<runtime-agent-id>

# Optional pre-minted runtime token. Usually generated at runtime instead.
# A365_BEARER_TOKEN=<minted-a365-access-token>

# ---------------------------------------------------------------------------
# Teams / Azure Bot / Agent 365 worker front end
# Used by configs/a365_worker.yml, configs/a365_frontend.yml, and
# configs/a365_email_notifications.yml
# ---------------------------------------------------------------------------
# Standard Teams bot: use the Azure Bot / Entra application client ID and secret.
# API-based worker lane: use the blueprint app ID and blueprint client secret.
A365_APP_ID=<agent-blueprint-id-or-azure-bot-microsoft-app-id>
A365_APP_PASSWORD=<agent-blueprint-secret-or-azure-bot-client-secret>

# Optional comma-separated audience aliases if inbound Teams JWT aud differs
# from A365_APP_ID. For API-based worker agents, set this to the Azure Bot
# Microsoft App ID / botMsaAppId.
A365_ALLOWED_AUDIENCES=<optional-botMsaAppId-or-comma-separated-audience-aliases>

# ---------------------------------------------------------------------------
# Graph mail MCP
# This server uses a delegated Graph token against /me/messages.
# Generate it with scripts/get_graph_mail_token.py and inject it at runtime.
# ---------------------------------------------------------------------------
# GRAPH_MAIL_TOKEN=<delegated-graph-mail-token>
GRAPH_MAIL_MCP_URL=https://<graph-mail-mcp-host>/mcp

# ---------------------------------------------------------------------------
# Optional Azure deployment helpers
# ---------------------------------------------------------------------------
ACA_RG=<azure-resource-group>
ACA_ENVIRONMENT=<azure-container-apps-environment>
ACA_APP=<container-app-name>

# ---------------------------------------------------------------------------
# Common runtime defaults
# ---------------------------------------------------------------------------
ENVIRONMENT=Production

# Useful commands:
#   export A365_BEARER_TOKEN="$(uv run python scripts/get_a365_token.py --decode)"
#   export GRAPH_MAIL_TOKEN="$(uv run python scripts/get_graph_mail_token.py)"
